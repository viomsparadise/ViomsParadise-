# Supabase
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Razorpay (public key only — never put the secret key in frontend env vars)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# Business contact (used by the Contact page + floating buttons)
VITE_WHATSAPP_NUMBER=919999999999
VITE_PHONE_NUMBER=+919999999999

# These two are SERVER-SIDE ONLY — set them in your Supabase Edge Function
# secrets (supabase secrets set ...), never in the Vite frontend env:
# RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
# RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxx
